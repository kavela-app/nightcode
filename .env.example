# nightcode - Claude Code When You Sleep
# Copy this file to .env and configure your settings

# ---- Required ----

# Your timezone (IANA format)
TZ=UTC

# ---- Optional ----

# GitHub personal access token (for gh CLI - PR creation)
# Generate at: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_xxxxx

# nightcode API auth token (for remote/team access)
# Auto-generated on first run if not set
# NIGHTCODE_AUTH_TOKEN=nc_your-secret-token

# Kavela MCP API key (for team context integration)
# Generate at: https://kavela.ai/dashboard?settings=apikeys
# KAVELA_API_KEY=kav_xxxxx

# Max concurrent tasks (default: 2)
# NIGHTCODE_MAX_CONCURRENT=2

# Port (default: 3777)
# NIGHTCODE_PORT=3777
